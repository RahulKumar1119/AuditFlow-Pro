# Production Environment Configuration
# AuditFlow-Pro Deployment Settings

# Environment
ENVIRONMENT=prod
AWS_REGION=ap-south-1

# Resource Naming
PROJECT_NAME=auditflow
STACK_NAME=auditflow-prod

# S3 Configuration
S3_BUCKET_PREFIX=auditflow-documents-prod
ENABLE_S3_VERSIONING=true
S3_LIFECYCLE_GLACIER_DAYS=90
S3_LIFECYCLE_EXPIRATION_DAYS=2555

# DynamoDB Configuration
DYNAMODB_BILLING_MODE=PAY_PER_REQUEST
ENABLE_POINT_IN_TIME_RECOVERY=true
TTL_ATTRIBUTE_NAME=ttl

# Lambda Configuration
LAMBDA_MEMORY_SIZE=2048
LAMBDA_TIMEOUT=300
LAMBDA_RUNTIME=python3.11
MAX_CONCURRENT_EXECUTIONS=100

# Step Functions Configuration
STEP_FUNCTION_NAME=AuditFlowWorkflow-prod

# API Gateway Configuration
API_GATEWAY_NAME=AuditFlowAPI-prod
API_STAGE_NAME=prod

# Cognito Configuration
USER_POOL_NAME=AuditFlowUserPool-prod
IDENTITY_POOL_NAME=AuditFlowIdentityPool-prod
SESSION_TIMEOUT_MINUTES=30
MFA_REQUIRED=true
ACCOUNT_LOCKOUT_ATTEMPTS=3
ACCOUNT_LOCKOUT_DURATION_MINUTES=15

# Security Configuration
ENABLE_KMS_ENCRYPTION=true
KMS_KEY_ROTATION_ENABLED=true
TLS_MINIMUM_VERSION=TLS_1_2

# Monitoring Configuration
LOG_RETENTION_DAYS=365
ENABLE_CLOUDWATCH_ALARMS=true
ALERT_EMAIL=prod-alerts@example.com

# Performance Configuration
CONFIDENCE_THRESHOLD=0.80
PROCESSING_TIMEOUT_SECONDS=300
RISK_SCORE_HIGH_THRESHOLD=50
RISK_SCORE_CRITICAL_THRESHOLD=80
MAX_FILE_SIZE_MB=50

# Tags
TAG_ENVIRONMENT=prod
TAG_PROJECT=auditflow-pro
TAG_MANAGED_BY=terraform
