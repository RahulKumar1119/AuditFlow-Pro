# Amplify Verification Configuration Example
# Copy this file to dev.env, staging.env, or prod.env and update with your values

# ============================================
# AWS Configuration
# ============================================
AWS_REGION=ap-south-1
ACCOUNT_ID=123456789012  # Replace with your AWS Account ID

# ============================================
# Amplify Configuration
# ============================================
AMPLIFY_APP_NAME=AuditFlow-Pro
CUSTOM_DOMAIN_NAME=auditflowpro.online  # Replace with your domain

# ============================================
# Frontend Environment Variables
# These should match what's configured in Amplify Console
# ============================================
VITE_API_GATEWAY_URL=https://api.auditflowpro.online
VITE_AWS_REGION=ap-south-1
VITE_COGNITO_USER_POOL_ID=ap-south-1_XXXXXXXXX  # Replace with your User Pool ID
VITE_COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX  # Replace with your Client ID
VITE_S3_BUCKET_NAME=auditflow-pro-documents

# ============================================
# Optional: Backend Integration
# ============================================
USER_POOL_ID=ap-south-1_XXXXXXXXX  # Same as VITE_COGNITO_USER_POOL_ID
API_GATEWAY_URL=https://api.auditflowpro.online  # Same as VITE_API_GATEWAY_URL

# ============================================
# How to Get These Values
# ============================================

# ACCOUNT_ID:
#   Run: aws sts get-caller-identity --query Account --output text

# AMPLIFY_APP_NAME:
#   Check AWS Amplify Console or run:
#   aws amplify list-apps --region ap-south-1 --query 'apps[].name'

# CUSTOM_DOMAIN_NAME:
#   Your custom domain configured in Amplify

# VITE_COGNITO_USER_POOL_ID:
#   AWS Console > Cognito > User Pools > Select your pool > General settings
#   Or run: aws cognito-idp list-user-pools --max-results 60 --region ap-south-1

# VITE_COGNITO_CLIENT_ID:
#   AWS Console > Cognito > User Pools > App clients
#   Or run: aws cognito-idp list-user-pool-clients --user-pool-id YOUR_POOL_ID

# VITE_API_GATEWAY_URL:
#   AWS Console > API Gateway > Your API > Stages > Stage URL
#   Or run: aws apigateway get-rest-apis --region ap-south-1

# ============================================
# Notes
# ============================================

# 1. Never commit this file with real values to Git
# 2. Add config/*.env to .gitignore (except *.env.example)
# 3. All VITE_* variables must be configured in Amplify Console
# 4. Update these values for each environment (dev, staging, prod)
