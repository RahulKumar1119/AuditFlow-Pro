# Development Environment Configuration
# AuditFlow-Pro Deployment Settings

# Environment
ENVIRONMENT=dev
AWS_REGION=ap-south-1

# Resource Naming
PROJECT_NAME=auditflow
STACK_NAME=auditflow-dev

# S3 Configuration
S3_BUCKET_PREFIX=auditflow-documents-dev
ENABLE_S3_VERSIONING=true
S3_LIFECYCLE_GLACIER_DAYS=90
S3_LIFECYCLE_EXPIRATION_DAYS=2555

# DynamoDB Configuration
DYNAMODB_BILLING_MODE=PAY_PER_REQUEST
ENABLE_POINT_IN_TIME_RECOVERY=false
TTL_ATTRIBUTE_NAME=ttl

# Lambda Configuration
LAMBDA_MEMORY_SIZE=512
LAMBDA_TIMEOUT=300
LAMBDA_RUNTIME=python3.11
MAX_CONCURRENT_EXECUTIONS=10

# Step Functions Configuration
STEP_FUNCTION_NAME=AuditFlowWorkflow-dev

# API Gateway Configuration
API_GATEWAY_NAME=AuditFlowAPI-dev
API_STAGE_NAME=dev

# Cognito Configuration
USER_POOL_NAME=AuditFlowUserPool-dev
IDENTITY_POOL_NAME=AuditFlowIdentityPool-dev
SESSION_TIMEOUT_MINUTES=30
MFA_REQUIRED=false
ACCOUNT_LOCKOUT_ATTEMPTS=3
ACCOUNT_LOCKOUT_DURATION_MINUTES=15

# Security Configuration
ENABLE_KMS_ENCRYPTION=true
KMS_KEY_ROTATION_ENABLED=true
TLS_MINIMUM_VERSION=TLS_1_2

# Monitoring Configuration
LOG_RETENTION_DAYS=30
ENABLE_CLOUDWATCH_ALARMS=false
ALERT_EMAIL=dev-alerts@example.com

# Performance Configuration
CONFIDENCE_THRESHOLD=0.80
PROCESSING_TIMEOUT_SECONDS=300
RISK_SCORE_HIGH_THRESHOLD=50
RISK_SCORE_CRITICAL_THRESHOLD=80
MAX_FILE_SIZE_MB=50

# Tags
TAG_ENVIRONMENT=dev
TAG_PROJECT=auditflow-pro
TAG_MANAGED_BY=terraform
