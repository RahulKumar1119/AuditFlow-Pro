
digraph AuditFlowProPremium {
    rankdir=TB;
    bgcolor=white;
    splines=curved;
    nodesep=0.8;
    ranksep=1.2;
    
    // Global settings
    node [fontname="Segoe UI, Arial", fontsize=10, shape=box, style="rounded,filled", margin="0.3,0.2"];
    edge [fontname="Segoe UI, Arial", fontsize=9, color="#555555"];
    
    // ============ TITLE ============
    title [label="AuditFlow-Pro: Serverless AI-Powered Loan Document Auditor", 
           shape=plaintext, fontsize=18, fontname="Arial Bold", fontcolor="#333333"];
    
    // ============ LAYER 1: CLIENT ============
    subgraph cluster_0 {
        label="Client Layer";
        style=filled;
        fillcolor="#F8F9FA";
        color="#CCCCCC";
        fontcolor="#333333";
        fontsize=12;
        fontname="Arial Bold";
        margin=20;
        
        client [label="👤 Loan Officer", fillcolor="#4A90E2", fontcolor=white, shape=box, width=2.5, height=0.8];
    }
    
    // ============ LAYER 2: FRONTEND ============
    subgraph cluster_1 {
        label="Frontend & Hosting (AWS Amplify)";
        style=filled;
        fillcolor="#F8F9FA";
        color="#CCCCCC";
        fontcolor="#333333";
        fontsize=12;
        fontname="Arial Bold";
        margin=20;
        
        frontend [label="React Dashboard\n(TypeScript + Vite)", fillcolor="#FF9900", fontcolor=white, shape=box, width=2.5, height=0.8];
        cdn [label="CloudFront\n(CDN)", fillcolor="#FF9900", fontcolor=white, shape=box, width=2.5, height=0.8];
    }
    
    // ============ LAYER 3: SECURITY ============
    subgraph cluster_2 {
        label="Security & Authentication";
        style=filled;
        fillcolor="#F8F9FA";
        color="#CCCCCC";
        fontcolor="#333333";
        fontsize=12;
        fontname="Arial Bold";
        margin=20;
        
        cognito [label="Amazon Cognito\n(User Pool)", fillcolor="#E74C3C", fontcolor=white, shape=box, width=2.5, height=0.8];
        kms [label="AWS KMS\n(Encryption)", fillcolor="#E74C3C", fontcolor=white, shape=box, width=2.5, height=0.8];
    }
    
    // ============ LAYER 4: API ============
    subgraph cluster_3 {
        label="API & Integration Layer";
        style=filled;
        fillcolor="#F8F9FA";
        color="#CCCCCC";
        fontcolor="#333333";
        fontsize=12;
        fontname="Arial Bold";
        margin=20;
        
        apigw [label="API Gateway\n(REST API)", fillcolor="#FF9900", fontcolor=white, shape=box, width=2.5, height=0.8];
        lambda_api [label="Lambda\n(API Handler)", fillcolor="#FF9900", fontcolor=white, shape=box, width=2.5, height=0.8];
    }
    
    // ============ LAYER 5: STORAGE ============
    subgraph cluster_4 {
        label="Storage Layer";
        style=filled;
        fillcolor="#F8F9FA";
        color="#CCCCCC";
        fontcolor="#333333";
        fontsize=12;
        fontname="Arial Bold";
        margin=20;
        
        s3 [label="Amazon S3\n(Document Storage)", fillcolor="#FF9900", fontcolor=white, shape=box, width=2.5, height=0.8];
        ddb_docs [label="DynamoDB\n(Document Metadata)", fillcolor="#3498DB", fontcolor=white, shape=box, width=2.5, height=0.8];
        ddb_audit [label="DynamoDB\n(Audit Records)", fillcolor="#3498DB", fontcolor=white, shape=box, width=2.5, height=0.8];
    }
    
    // ============ LAYER 6: ORCHESTRATION ============
    subgraph cluster_5 {
        label="Orchestration Layer";
        style=filled;
        fillcolor="#F8F9FA";
        color="#CCCCCC";
        fontcolor="#333333";
        fontsize=12;
        fontname="Arial Bold";
        margin=20;
        
        stepfn [label="AWS Step Functions\n(State Machine)", fillcolor="#FF9900", fontcolor=white, shape=box, width=2.5, height=0.8];
    }
    
    // ============ LAYER 7: PROCESSING ============
    subgraph cluster_6 {
        label="Processing Pipeline (Lambda Functions)";
        style=filled;
        fillcolor="#F8F9FA";
        color="#CCCCCC";
        fontcolor="#333333";
        fontsize=12;
        fontname="Arial Bold";
        margin=20;
        
        classify [label="Classifier\nLambda", fillcolor="#FF9900", fontcolor=white, shape=box, width=2, height=0.7];
        extract [label="Extractor\nLambda", fillcolor="#FF9900", fontcolor=white, shape=box, width=2, height=0.7];
        validate [label="Validator\nLambda", fillcolor="#FF9900", fontcolor=white, shape=box, width=2, height=0.7];
        score [label="Risk Scorer\nLambda", fillcolor="#FF9900", fontcolor=white, shape=box, width=2, height=0.7];
        report [label="Reporter\nLambda", fillcolor="#FF9900", fontcolor=white, shape=box, width=2, height=0.7];
    }
    
    // ============ LAYER 8: AI/ML ============
    subgraph cluster_7 {
        label="AI/ML Services";
        style=filled;
        fillcolor="#F8F9FA";
        color="#CCCCCC";
        fontcolor="#333333";
        fontsize=12;
        fontname="Arial Bold";
        margin=20;
        
        textract [label="Textract\n(OCR)", fillcolor="#27AE60", fontcolor=white, shape=box, width=2, height=0.7];
        comprehend [label="Comprehend\n(PII Detection)", fillcolor="#27AE60", fontcolor=white, shape=box, width=2, height=0.7];
        bedrock [label="Bedrock\n(Claude Sonnet 4)", fillcolor="#27AE60", fontcolor=white, shape=box, width=2, height=0.7];
    }
    
    // ============ LAYER 9: MONITORING ============
    subgraph cluster_8 {
        label="Monitoring & Alerts";
        style=filled;
        fillcolor="#F8F9FA";
        color="#CCCCCC";
        fontcolor="#333333";
        fontsize=12;
        fontname="Arial Bold";
        margin=20;
        
        cw [label="CloudWatch\n(Logs & Metrics)", fillcolor="#9B59B6", fontcolor=white, shape=box, width=2.5, height=0.8];
        sns [label="SNS\n(Notifications)", fillcolor="#E74C3C", fontcolor=white, shape=box, width=2.5, height=0.8];
    }
    
    // ============ DATA FLOWS ============
    
    // Client to Frontend
    client -> frontend [label="Access", color="#4A90E2", penwidth=2.5];
    frontend -> cdn [label="Serve", color="#333333", penwidth=1.5, style=dashed];
    
    // Frontend to API
    cdn -> apigw [label="API Calls", color="#4A90E2", penwidth=2.5];
    apigw -> cognito [label="Authenticate", color="#E74C3C", penwidth=2.5];
    apigw -> lambda_api [label="Route", color="#333333", penwidth=2.5];
    
    // API to Storage
    lambda_api -> s3 [label="Upload", color="#FF9900", penwidth=2.5];
    lambda_api -> ddb_docs [label="Query", color="#3498DB", penwidth=1.5, style=dashed];
    
    // S3 to Orchestration
    s3 -> stepfn [label="Trigger Event", color="#FF6B6B", penwidth=2.5];
    
    // Orchestration to Processing
    stepfn -> classify [label="Start", color="#333333", penwidth=2.5];
    
    // Processing Pipeline
    classify -> textract [label="Analyze", color="#27AE60", penwidth=2.5];
    textract -> extract [label="Extract", color="#333333", penwidth=2.5];
    extract -> comprehend [label="Detect PII", color="#27AE60", penwidth=2.5];
    extract -> validate [label="Validate", color="#333333", penwidth=2.5];
    validate -> bedrock [label="Reason", color="#27AE60", penwidth=2.5];
    validate -> score [label="Score", color="#333333", penwidth=2.5];
    score -> report [label="Report", color="#333333", penwidth=2.5];
    
    // Storage
    classify -> ddb_docs [label="Save", color="#3498DB", penwidth=1.5];
    extract -> ddb_docs [label="Save", color="#3498DB", penwidth=1.5];
    report -> ddb_audit [label="Save", color="#3498DB", penwidth=2.5];
    
    // Alerts
    report -> sns [label="Alert", color="#E74C3C", penwidth=2.5];
    sns -> client [label="Notify", color="#E74C3C", penwidth=2.5];
    
    // Monitoring
    classify -> cw [label="Log", color="#9B59B6", penwidth=1.5, style=dashed];
    extract -> cw [label="Log", color="#9B59B6", penwidth=1.5, style=dashed];
    validate -> cw [label="Log", color="#9B59B6", penwidth=1.5, style=dashed];
    score -> cw [label="Log", color="#9B59B6", penwidth=1.5, style=dashed];
    report -> cw [label="Log", color="#9B59B6", penwidth=1.5, style=dashed];
    
    // Encryption
    s3 -> kms [label="Encrypt", color="#E74C3C", penwidth=1.5, style=dotted];
    ddb_docs -> kms [label="Encrypt", color="#E74C3C", penwidth=1.5, style=dotted];
    ddb_audit -> kms [label="Encrypt", color="#E74C3C", penwidth=1.5, style=dotted];
    
    // ============ LEGEND ============
    subgraph cluster_legend {
        label="Legend & Key Features";
        style=filled;
        fillcolor="#FFFACD";
        color="#CCCCCC";
        fontcolor="#333333";
        fontsize=11;
        fontname="Arial";
        margin=15;
        
        legend_text [label="Message Flow (solid) | Authentication (red) | Logging (dashed) | Encryption (dotted)\n\nKey Features:\n✓ Multi-document parallel processing  ✓ AI-powered cross-document validation  ✓ Real-time risk scoring\n✓ Automated SNS alerts  ✓ Comprehensive CloudWatch logging  ✓ Banking-grade KMS encryption", 
                    shape=box, style=filled, fillcolor=white, fontsize=9, fontname="Arial", fontcolor="#333333"];
    }
}
